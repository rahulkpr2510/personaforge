generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String     @id @default(cuid())
  clerkId   String     @unique
  email     String     @unique
  name      String?
  role      UserRole   @default(USER)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  analyses  Analysis[]
  personas  Persona[]

  @@index([clerkId])
  @@index([role])
}

model Persona {
  id               String            @id @default(cuid())
  ownerId          String?
  label            String            @unique
  name             String
  age              Int
  occupation       String
  technicalLevel   TechnicalLevel
  goals            String
  frustrations     String
  isPrebuilt       Boolean           @default(false)
  isActive         Boolean           @default(true)
  tags             String[]          @default([])
  metadata         Json?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  analysisPersonas AnalysisPersona[]
  owner            User?             @relation(fields: [ownerId], references: [id])

  @@unique([ownerId, label])
  @@index([ownerId])
  @@index([isPrebuilt, isActive])
}

model Analysis {
  id                   String             @id @default(cuid())
  userId               String
  url                  String
  normalizedHost       String
  status               AnalysisStatus     @default(PENDING)
  deviceType           DeviceType         @default(DESKTOP)
  maxDepth             Int                @default(2)
  maxPages             Int                @default(8)
  overallSentiment     SentimentLabel?
  overallFrictionScore Int?
  summary              String?
  meta                 Json?
  error                String?
  startedAt            DateTime?
  completedAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  analysisInput        Json?
  user                 User               @relation(fields: [userId], references: [id])
  personas             AnalysisPersona[]
  focusGroup           FocusGroupInsight?
  pages                Page[]

  @@index([userId, createdAt])
  @@index([normalizedHost])
  @@index([status])
}

model Page {
  id                 String       @id @default(cuid())
  analysisId         String
  url                String
  path               String?
  title              String?
  depth              Int
  content            String?
  formsCount         Int          @default(0)
  buttonsCount       Int          @default(0)
  linksCount         Int          @default(0)
  textLength         Int          @default(0)
  hasAuthForm        Boolean      @default(false)
  primaryActionLabel String?
  performance        Json?
  accessibility      Json?
  navStructure       Json?
  visionMeta         Json?
  frictionScore      Int?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  analysis           Analysis     @relation(fields: [analysisId], references: [id])
  screenshots        Screenshot[]

  @@index([analysisId, depth])
  @@index([url])
}

model Screenshot {
  id        String         @id @default(cuid())
  pageId    String
  cdnUrl    String
  type      ScreenshotType @default(FULL_PAGE)
  width     Int?
  height    Int?
  createdAt DateTime       @default(now())
  page      Page           @relation(fields: [pageId], references: [id])

  @@index([pageId])
}

model AnalysisPersona {
  id                 String          @id @default(cuid())
  analysisId         String
  personaId          String?
  label              String
  name               String
  age                Int
  occupation         String
  technicalLevel     TechnicalLevel
  goals              String
  frustrations       String
  firstImpressions   String?
  positives          String?
  painPoints         String?
  recommendations    String?
  accessibilityNotes String?
  adoptionLikelihood Int?
  sentiment          SentimentLabel?
  frictionScore      Int?
  evidence           Json?
  rawModelOutput     Json?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  analysis           Analysis        @relation(fields: [analysisId], references: [id])
  persona            Persona?        @relation(fields: [personaId], references: [id])

  @@index([analysisId])
  @@index([personaId])
  @@index([sentiment])
}

model FocusGroupInsight {
  id         String   @id @default(cuid())
  analysisId String   @unique
  summary    String
  conflicts  Json
  createdAt  DateTime @default(now())
  analysis   Analysis @relation(fields: [analysisId], references: [id])
}

enum UserRole {
  USER
  ADMIN
}

enum AnalysisStatus {
  PENDING
  CRAWLING
  ANALYZING
  COMPLETED
  FAILED
}

enum TechnicalLevel {
  LOW
  MEDIUM
  HIGH
}

enum DeviceType {
  DESKTOP
  MOBILE
}

enum SentimentLabel {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

enum ScreenshotType {
  FULL_PAGE
  VIEWPORT
}
